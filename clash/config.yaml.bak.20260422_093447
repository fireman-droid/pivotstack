port: 7890
socks-port: 7891
allow-lan: true
mode: rule
log-level: info
external-controller: 127.0.0.1:9090
dns:
  enable: true
  enhanced-mode: fake-ip
  ipv6: true
  nameserver:
    - https://120.53.53.53/dns-query
    - https://223.5.5.5/dns-query
  nameserver-policy:
    geosite:cn,private:
      - https://120.53.53.53/dns-query
      - https://223.5.5.5/dns-query
    geosite:geolocation-!cn:
      - https://dns.cloudflare.com/dns-query
      - https://dns.google/dns-query
  proxy-server-nameserver:
    - https://120.53.53.53/dns-query
    - https://223.5.5.5/dns-query
  respect-rules: true
proxies:
  - name: tw-04
    type: anytls
    server: 7c4b1e93.911-gt3-rs.com
    port: 35122
    password: 15de2fdc-1d3b-4655-ada8-9b238eee0655
    client-fingerprint: chrome
    udp: true
    alpn: [h2, http/1.1]
    sni: dl.emsfi.com
  - name: tw-05
    type: anytls
    server: 7c4b1e93.911-gt3-rs.com
    port: 35131
    password: 15de2fdc-1d3b-4655-ada8-9b238eee0655
    client-fingerprint: chrome
    udp: true
    alpn: [h2, http/1.1]
    sni: dl.emsfi.com
  - name: tw-07
