# ============================================
# Kiro Stack 配置文件
# 复制为 .env 后修改
# ============================================

# 管理面板登录密码
ADMIN_PASSWORD=changeme

# 内部服务通信密钥
INTERNAL_API_KEY=changeme

# 代理地址（国内服务器必填，海外可留空）
# 支持 http/https/socks5 协议
VPN_PROXY_URL=http://host.docker.internal:7890

# 调试模式 off / errors / all
DEBUG_MODE=off
