# ==============================
# 敏感数据 / Sensitive Data
# ==============================

# 根目录环境变量（含密码和密钥）
.env
.env.local

# kiro-go 运行时数据（含 Token、日志）
kiro-go/data/config.json
kiro-go/data/call_logs.jsonl

# clash 节点配置（含密码不能进 git；服务器侧已备份到 /root/kiro-clash-backup/）
clash/config.yaml

# kiro-gateway 环境变量（已废弃，现在统一用根目录 .env）
kiro-gateway/.env
kiro-gateway/.env.local

