# PivotStack 部署环境变量模板。
# 在 JP server 上 cp .env.example .env 后填写。
# .env 已在 .gitignore；千万不要 commit 真实值。

# === 必填 ===
# Postgres 主数据库密码（v10 PG 后端 / 持久化层依赖）。
# 推荐用 openssl rand -base64 32 生成。
POSTGRES_PASSWORD=

# === 强烈建议 ===
# 应用层加密密钥（v10 plan §2.7：API key/refresh token 在 PG 落盘前 AES-GCM 加密）。
# 32+ 字节强随机串。一旦设置就不能变（否则历史加密数据解不开）。
PIVOTSTACK_ENCRYPTION_KEY=

# 生产环境标记。等于 "production" 时强制要求 PIVOTSTACK_ENCRYPTION_KEY 必填，
# 避免无意中用弱默认密钥派生。
PIVOTSTACK_ENV=production

# === 可选 ===
# 跨域允许的前端域名（admin / user 分域时配；逗号分隔）
# PIVOTSTACK_ALLOWED_ORIGINS=https://admin.psk.edu.pl,https://psk.edu.pl

# JP server 通常不需要 clash 代理，留空即可。注释掉 docker-compose.yml 里的 VPN_PROXY_URL。
# VPN_PROXY_URL=

# PG 备份保留天数（默认 30）
BACKUP_RETENTION_DAYS=30

# v10 PG 后端切流开关（Stage A 期保持空 / json；Stage C cutover 时改 pg）
# STORAGE_BACKEND=json
# DATABASE_URL=postgres://pivotstack:${POSTGRES_PASSWORD}@postgres:5432/pivotstack?sslmode=disable
